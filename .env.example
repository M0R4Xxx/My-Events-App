# Database URL dari penyedia database (contoh: Neon, Supabase, dll)
DATABASE_URL=

# Direct URL khusus untuk migrasi Prisma (biasanya sama dengan DATABASE_URL tapi dengan parameter tambahan)
DIRECT_URL=

# URL aplikasi saat berjalan di lingkungan lokal
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret key untuk enkripsi JWT (gunakan string acak yang panjang dan aman)
JWT_SECRET=

# Konfigurasi email untuk pengiriman notifikasi/undangan
EMAIL_USER=
EMAIL_PASS=

# Token autentikasi untuk layanan upload gambar (UploadThing)
UPLOADTHING_TOKEN=